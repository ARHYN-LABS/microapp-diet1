{
  "expo": {
    "name": "SafePlate AI",
    "scheme": "safeplate",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "slug": "whats-in-my-food",
    "version": "1.0.7",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access to identify products."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "safeplate"
            }
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F8FAFC"
      },
      "package": "com.askmobisoft55.whatsinmyfood",
      "versionCode": 29
    },
    "extra": {
      "apiBase": "${EXPO_PUBLIC_API_BASE}",
      "userId": "${EXPO_PUBLIC_USER_ID}",
      "eas": {
        "projectId": "f69b269a-e71d-4cf8-b2ba-bc15955ae252"
      }
    }
  }
}
